fn fibonacci(int n) -> int {
    int result = 0;
    int b = 1;
    int tmp = 0;
    int i = 0;

    for (i = 0; i < n; i = i + 1) {
        tmp = result;
        result = b;
        b = b + tmp;
    }

    return result;
}

fn main() -> void {
    int n = 10;
    int result;

    result = fibonacci(n);
}