fn fibonacci(int n) -> int {
    int a = 0;
    int b = 1;
    int i = 0;
    int temp = 0;
    
    if (n == 0) {
        return 0;
    }
    
    if (n == 1) {
        return 1;
    }
    
    for (i = 2; i <= n; i = i + 1) {
        temp = a + b;
        a = b;
        b = temp;
    }
    
    return b;
}

fn main() -> int {
    int result = fibonacci(7);
    return result;
}